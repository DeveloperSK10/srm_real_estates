rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Admins can read all user data, users can read/write their own.
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /locations/{locationId} {
      allow read: if request.auth != null;
    }

    match /property_preferences/{userId} {
      // Admins can read all preferences, users can read/write their own.
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}